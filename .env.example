# FastAPI Configuration
ENVIRONMENT=development
DEBUG=True
API_TITLE=AI Agent Credit System
API_VERSION=1.0.0

# Database Configuration

# === SUPABASE (Recommended) ===
# Get these from https://supabase.com
# 1. Create a new project
# 2. Copy URL and API keys from project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Optional: Admin key for admin operations (keep this private!)
# SUPABASE_ADMIN_KEY=your-admin-key-here

# === MONGODB (Alternative) ===
# MONGODB_URL=mongodb://localhost:27017/ai_credit_system
# MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/ai_credit_system

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Blockchain/Testnet Configuration
# BLOCKCHAIN_PROVIDER_URL=https://sepolia.infura.io/v3/YOUR-PROJECT-ID
# ETHEREUM_TESTNET=sepolia
# WALLET_ADDRESS=0x...

# Security
SECRET_KEY=your-secret-key-change-in-production

# Logging
LOG_LEVEL=INFO

# ==========================================
# FRONTEND (Vite + React) Configuration
# ==========================================
# API endpoint for frontend-to-backend communication
# Used in src/services/api.ts for all backend requests
VITE_API_URL=http://127.0.0.1:8000

# Frontend environment (development/production)
VITE_ENV=development
