# FastAPI Configuration
ENVIRONMENT=development
DEBUG=True
API_TITLE=AI Agent Credit System
API_VERSION=1.0.0

# Database Configuration
# MONGODB_URL=mongodb://localhost:27017/ai_credit_system
# MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/ai_credit_system

# Supabase Configuration (Alternative to MongoDB)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_API_KEY=your-api-key

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Blockchain/Testnet Configuration
# BLOCKCHAIN_PROVIDER_URL=https://sepolia.infura.io/v3/YOUR-PROJECT-ID
# ETHEREUM_TESTNET=sepolia
# WALLET_ADDRESS=0x...

# Security
SECRET_KEY=your-secret-key-change-in-production

# Logging
LOG_LEVEL=INFO
